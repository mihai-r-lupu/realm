{
  "name": "realm",
  "private": true,
  "packageManager": "npm@11.8.0",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dashboard": "node scripts/dashboard.mjs",
    "postinstall": "lefthook install"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "jiti": "^2.0.0",
    "lefthook": "^2.1.6",
    "prettier": "^3.2.0",
    "turbo": "latest",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "openai": "^6.34.0"
  }
}
