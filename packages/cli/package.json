{
  "name": "@sensigo/realm-cli",
  "version": "0.1.0",
  "description": "Run autonomous agent workflows, host an MCP server over HTTP, and manage workflow definitions and run history from the terminal.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/sensigo-hq/realm.git"
  },
  "homepage": "https://github.com/sensigo-hq/realm#readme",
  "keywords": [
    "workflow",
    "cli",
    "ai-agent",
    "agent-workflow",
    "mcp",
    "typescript"
  ],
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./commands": {
      "import": "./dist/commands-registry.js",
      "types": "./dist/commands-registry.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "peerDependencies": {
    "openai": ">=4.0.0",
    "@anthropic-ai/sdk": ">=0.20.0"
  },
  "peerDependenciesMeta": {
    "openai": {
      "optional": true
    },
    "@anthropic-ai/sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "typescript": "*",
    "vitest": "*"
  },
  "dependencies": {
    "@sensigo/realm": "*",
    "@sensigo/realm-mcp": "*",
    "@sensigo/realm-testing": "*",
    "@modelcontextprotocol/sdk": "1.29.0",
    "chalk": "^5.0.0",
    "commander": "^14.0.3",
    "dotenv": "^17.4.0",
    "js-yaml": "^4.1.1"
  },
  "bin": {
    "realm": "./dist/index.js"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
