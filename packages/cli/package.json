{
  "name": "@sensigo/realm-cli",
  "version": "0.1.0",
  "description": "CLI for Realm — 16 commands for building, testing, operating, and serving workflows.",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./commands": {
      "import": "./dist/commands-registry.js",
      "types": "./dist/commands-registry.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "typescript": "*",
    "vitest": "*"
  },
  "dependencies": {
    "@sensigo/realm": "*",
    "@sensigo/realm-mcp": "*",
    "@sensigo/realm-testing": "*",
    "@modelcontextprotocol/sdk": "1.29.0",
    "chalk": "^5.0.0",
    "commander": "*",
    "js-yaml": "*"
  },
  "bin": {
    "realm": "./dist/index.js"
  }
}
