# LLM provider — at least one is required to run realm agent
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# GitHub token — required for workflows that read PRs or repo content
GITHUB_TOKEN=

# Slack webhook URL — optional; enables gate notifications to a Slack channel
SLACK_WEBHOOK_URL=

# Slack bot token + channel — required for Mode 2 (Socket Mode) and Mode 3 (Events API)
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_CHANNEL_ID=C...

# Slack App-level token — enables Socket Mode (Mode 2). Get from Settings → Socket Mode → App-Level Tokens.
# SLACK_APP_TOKEN=xapp-...

# Slack signing secret — enables Events API (Mode 3). Get from Settings → Basic Information.
# SLACK_SIGNING_SECRET=...

# Google Docs API token
GDOCS_TOKEN=

# Bubble API key
BUBBLE_API_KEY=

# Disable Turbo telemetry
TURBO_TELEMETRY_DISABLED=1
