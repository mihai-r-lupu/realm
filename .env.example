# LLM provider — at least one is required to run realm agent
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# GitHub token — required for workflows that read PRs or repo content
GITHUB_TOKEN=

# Slack webhook URL — optional; enables gate notifications to a Slack channel
SLACK_WEBHOOK_URL=

# Google Docs API token
GDOCS_TOKEN=

# Bubble API key
BUBBLE_API_KEY=

# Disable Turbo telemetry
TURBO_TELEMETRY_DISABLED=1
